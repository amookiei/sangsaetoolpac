# ─── Supabase (외부 DB + 로그인) — 설정하면 클라우드 모드 자동 활성화 ───
# supabase.com → 프로젝트 생성 → Settings → API 에서 복사
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# 이 이메일로 로그인하면 관리자 모드 (Supabase Auth에 계정 먼저 생성)
VITE_ADMIN_EMAIL=

# ─── Gemini (나노바나나 이미지 생성 + 본문 번역) ───
# aistudio.google.com 에서 무료 발급. 설정하면 사용자가 키를 입력하지 않아도 기본 적용
VITE_GEMINI_KEY=

# ─── OpenAI (선택 — gpt-image-1 프록시 /api/openai-image 용, 서버 전용) ───
OPENAI_API_KEY=
